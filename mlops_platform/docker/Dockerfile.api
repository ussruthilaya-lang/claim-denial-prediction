FROM python:3.11-slim

WORKDIR /app

COPY shared/ shared/
COPY mlops_platform/serving/ mlops_platform/serving/
COPY mlops_platform/requirements.txt mlops_platform/requirements.txt

RUN pip install --no-cache-dir -r mlops_platform/requirements.txt

EXPOSE 8000

CMD ["uvicorn", "mlops_platform.serving.app:app", "--host", "0.0.0.0", "--port", "8000"]
