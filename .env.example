# Copy to .env and fill in. Never commit the real .env.

# --- MLflow (local, via docker compose) ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=claim-denial-prediction

# --- Phase 4: RAG / Agentic layer ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
FAISS_INDEX_PATH=./phase4_rag_agentic/index/claims.faiss
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Phase 3: ClinicalBERT / MIMIC-IV-Note ---
# Requires PhysioNet credentialed access (free CITI training) — do not hardcode paths to raw notes
MIMIC_NOTE_DATA_DIR=

# --- Serving API ---
API_PORT=8000
MODEL_STAGE=production   # which MLflow-registered model the API loads

# --- GCP (only needed once you deploy past local docker compose) ---
GCP_PROJECT_ID=
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=./gcp-service-account.json
