# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Env / secrets
.env
*.pem
gcp-service-account*.json

# Data — never commit raw PHI-adjacent or large data. Use DVC pointers instead.
data/raw/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep
*.csv
*.parquet
!**/samples/*.csv

# MIMIC-IV-Note requires CITI training + PhysioNet credentialing.
# Never commit discharge summaries or any derived text under this path.
phase3_clinicalbert/data/*
!phase3_clinicalbert/data/.gitkeep

# FAISS indexes are large binary artifacts — store via DVC/GCS, not git
phase4_rag_agentic/index/*.faiss
phase4_rag_agentic/index/*.pkl

# Phase 4 generated artifacts — regenerable via `python scripts/run_phase4.py`.
# Keep figures/ and metrics.json (small, needed for the report); ignore the
# large binaries (index vectors, model bundle, prediction dumps).
phase4_rag_agentic/artifacts/*.pkl
phase4_rag_agentic/artifacts/*.npy
phase4_rag_agentic/artifacts/*.parquet

# Jupyter
.ipynb_checkpoints/

# OS
.DS_Store
